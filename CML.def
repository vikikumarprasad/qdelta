Bootstrap: docker
From: ubuntu:22.04

%setup
    # Pre-create auto-mounted targets for Compute Canada compatibility
    mkdir -p $SINGULARITY_ROOTFS/lustre06/project
    mkdir -p $SINGULARITY_ROOTFS/project
    mkdir -p $SINGULARITY_ROOTFS/lustre07/scratch
    mkdir -p $SINGULARITY_ROOTFS/scratch

%post
    export DEBIAN_FRONTEND=noninteractive

    # Install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        python3 \
        python3-pip \
        python3-dev \
        cmake \
        rustc \
        cargo \
        pkg-config \
        libgmp-dev \
        libxml2-dev \
        libgl1 \
        libgl1-mesa-glx \
        libglib2.0-0 \
        tzdata \
        git \
        curl \
        wget

    # Set timezone
    ln -fs /usr/share/zoneinfo/Etc/UTC /etc/localtime
    dpkg-reconfigure -f noninteractive tzdata

    # Upgrade pip
    pip3 install --no-cache-dir --upgrade pip

    # Install numpy FIRST and lock to compatible version
    pip3 install --no-cache-dir numpy==1.24.4

    # Install Python packages for classical ML and visualization
    pip3 install --no-cache-dir \
        pandas \
        matplotlib \
        seaborn \
        scikit-learn==1.2.2 \
        xgboost \
        shap \
        optuna \
        optuna-integration \
        joblib

    # Install TensorFlow for deep learning
    pip3 install --no-cache-dir tensorflow==2.13.0

# --- ADD THIS SECTION ---
%files
    # Copy your entire CML_Models directory into the /app directory inside the container
    # Make sure this source path is correct for your system
    /home/armaank/projects/def-vikikrpd/armaank/Code_Files/CML_Models /app

%environment
    export PYTHONUNBUFFERED=1
    export MPLCONFIGDIR=/tmp/matplotlib
    export PATH="/usr/local/bin:$PATH"

%runscript
    echo "Apptainer container for classical + deep ML models is ready."
    echo "Run your script using: python3 your_script.py"